{
  "manifest_version": 3,
  "name": "Futbin Player Monitor",
  "version": "0.2.0",
  "description": "Futbin sayfalarını sırayla açar ve yüklenen oyuncu verilerini izler.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://www.futbin.com/*", "https://futbin.com/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Futbin Player Monitor"
  },
  "content_scripts": [
    {
      "matches": ["https://www.futbin.com/*", "https://futbin.com/*"],
      "js": ["src/page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.futbin.com/*", "https://futbin.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ]
}
