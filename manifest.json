{
  "manifest_version": 3,
  "name": "Futbin Player Monitor",
  "version": "0.3.0",
  "description": "Backend kuyruğundaki lig ve kulüplerin Futbin oyuncularını tarayıp senkronize eder.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://www.futbin.com/*",
    "https://futbin.com/*",
    "http://localhost:5055/*",
    "https://api.sbcmonster.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Futbin Player Monitor",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.futbin.com/*", "https://futbin.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ]
}
